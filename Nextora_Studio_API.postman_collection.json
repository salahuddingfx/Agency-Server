    {
      "name": "Services",
      "item": [
        {
          "name": "Get Services",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{BASE_URL}}/services?category=Engineering&sort=-createdAt",
              "host": ["{{BASE_URL}}"],
              "path": ["services"],
              "query": [
                { "key": "category", "value": "Engineering" },
                { "key": "sort", "value": "-createdAt" }
              ]
            }
          }
        },
        {
          "name": "Create Service",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{ACCESS_TOKEN}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Cloud Architecture Audit\",\n  \"category\": \"Engineering\",\n  \"metric\": \"60% Savings SLA\",\n  \"status\": \"Published\",\n  \"shortDesc\": \"Review server infrastructure and reduce hosting monthly costs.\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/services",
              "host": ["{{BASE_URL}}"],
              "path": ["services"]
            }
          }
        }
      ]
    }
