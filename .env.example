# Server Config
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173
ADMIN_URL=http://localhost:5174

# Database Config
MONGO_URI=mongodb://127.0.0.1:27017/nextora

# JWT Secrets
JWT_ACCESS_SECRET=nextora_access_token_secret_key_2026_super_secure
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_SECRET=nextora_refresh_token_secret_key_2026_super_secure
JWT_REFRESH_EXPIRY=7d

# Nodemailer / SMTP Config
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_USER=mock-user@ethereal.email
SMTP_PASS=mock-password
SMTP_FROM="Nextora Studio" <noreply@nextora.tech>

# Cloudinary Config (Optional - will fall back to local disk logging if empty)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
